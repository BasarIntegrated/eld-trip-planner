DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Local Postgres (optional — defaults to SQLite when unset)
# PGDATABASE=eld_trip_planner_dev
# PGUSER=postgres
# PGPASSWORD=
# PGHOST=localhost
# PGPORT=5432

# Railway: reference Postgres service variables on the api service (official guide):
# PGDATABASE=${{Postgres.PGDATABASE}}
# PGUSER=${{Postgres.PGUSER}}
# PGPASSWORD=${{Postgres.PGPASSWORD}}
# PGHOST=${{Postgres.PGHOST}}
# PGPORT=${{Postgres.PGPORT}}
#
# Alternatively, DATABASE_URL=${{Postgres.DATABASE_URL}} also works.

# Optional — limit anonymous API requests (default 30/minute)
# API_ANON_THROTTLE=30/minute
